{
  "allow_shell": false,
  "confirm_writes": true,
  "confirm_exec": true,
  "web": {
    "search_provider": "searxng",
    "enabled": true,
    "search_api_endpoint": "http://127.0.0.1:8081/search",
    "allow_domains": [
      "tea.texas.gov",
      "txschools.gov",
      "tea4avcastro.tea.texas.gov",
      "region1.net",
      "texasstudentdatasystem.org",
      "tsds.txschools.gov",
      "weather.com",
      "api.weather.gov",
      "esp.bisd.us"
    ],
    "max_bytes": 20000000,
    "research_domains_limit": 4,
    "research_pages_per_domain": 8,
    "research_scan_pages_per_domain": 12,
    "research_max_depth": 1,
    "research_seeds_per_domain": 8,
    "research_max_results": 8,
    "research_min_score": 3.0,
    "search_provider_priority": [
      "wikipedia",
      "stackexchange",
      "general_web"
    ],
    "stackexchange_site": "stackoverflow",
    "stackexchange_api_endpoint": "https://api.stackexchange.com/2.3/search/advanced",
    "stackexchange_api_key_env": "STACKEXCHANGE_API_KEY",
    "github_api_key_env": "GITHUB_TOKEN"
  },
  "allowed_root": "C:\\Nova",
  "tools_enabled": {
    "screen": true,
    "camera": true,
    "files": true,
    "health": true,
    "web": true
  },
  "models": {
    "chat": "llama3.1:8b",
    "vision": "qwen2.5vl:7b",
    "stt_size": "base"
  },
  "memory": {
    "enabled": true,
    "mode": "B",
    "scope": "hybrid",
    "top_k": 5,
    "context_top_k": 3,
    "min_score": 0.18,
    "store_min_chars": 12,
    "store_include_patterns": [
      "^remember this",
      "^learned_fact:",
      "\\b(my name is|my location is|i live in|i work in|my favorite)\\b"
    ],
    "store_exclude_patterns": [
      "^tip:",
      "^network error:",
      "^loading",
      "^please try:"
    ],
    "exclude_sources": [
      "voice"
    ]
  },
  "patch": {
    "strict_manifest": true,
    "enabled": true,
    "allow_force": false,
    "behavioral_check": true,
    "behavioral_check_timeout_sec": 600
  },
  "safety_envelope": {
    "enabled": true,
    "mode": "enforce",
    "replay_threshold": 1.0,
    "replay_attempts": 2,
    "novelty_min": 0.35,
    "entropy_min": 2.8,
    "diversity_min_messages": 3,
    "human_veto_first_n": 3,
    "auto_demote_threshold": 0.98,
    "max_candidates_per_cycle": 12,
    "full_regression_required": false,
    "quarantine_root": "C:\\Nova\\runtime\\test_sessions\\quarantine",
    "pending_review_root": "C:\\Nova\\runtime\\test_sessions\\pending_review"
  },
  "kidney": {
    "enabled": true,
    "mode": "enforce",
    "definition_max_age_days": 7,
    "definition_novelty_min": 0.4,
    "quarantine_max_age_hours": 48,
    "preview_max_age_days": 3,
    "snapshot_max_age_days": 30,
    "temp_max_age_days": 14,
    "temp_max_total_mb": 500,
    "protect_patterns": []
  }
}
